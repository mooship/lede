{
  "name": "@elar/api-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --test-scheduled",
    "build": "tsc --noEmit",
    "deploy": "wrangler secret bulk .secrets.production.json --env production && wrangler deploy --env production",
    "test": "vitest run",
    "lint": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@hono/trpc-server": "latest",
    "@elar/api": "*",
    "@elar/db": "*",
    "@neondatabase/serverless": "latest",
    "@trpc/server": "latest",
    "drizzle-orm": "latest",
    "fast-xml-parser": "^5.5.6",
    "hono": "latest",
    "ofetch": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@elar/tsconfig": "*",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
