{
  "name": "tidel-web",
  "compatibility_date": "2026-03-20",
  "compatibility_flags": ["nodejs_compat"],
  "main": "dist/server/index.js",
  "assets": { "directory": "dist/client" },
  "vars": {
    "API_URL": "http://localhost:8787"
  },
  "env": {
    "production": {
      "vars": {
        "API_URL": "https://api.tidel.app"
      }
    }
  }
}
