{
  "name": "tidel-app",
  "compatibility_date": "2026-03-17",
  "compatibility_flags": ["nodejs_compat"],
  "main": "dist/server/index.js",
  "assets": { "directory": "dist/client" },
  "placement": { "mode": "smart" },
  "workers_dev": false,
  "preview_urls": false,
  "vars": {
    "API_URL": "https://api.tidel.app"
  },
  "observability": {
    "enabled": true
  }
}
