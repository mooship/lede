{
  "name": "@tidel/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "panda codegen --silent",
    "dev": "panda codegen --silent && vite dev",
    "build": "panda codegen --silent && tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy --config wrangler.deploy.jsonc --env production",
    "test": "vitest run",
    "lint": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-start": "^1.166.18",
    "@tidel/api": "*",
    "@trpc/client": "latest",
    "@trpc/react-query": "latest",
    "ofetch": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@fontsource-variable/syne": "latest",
    "@fontsource/instrument-serif": "latest",
    "@pandacss/dev": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@tidel/tsconfig": "*",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "fontaine": "latest",
    "happy-dom": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
