{
  "name": "@tidel/web",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "prepare": "panda codegen --silent",
    "dev": "panda codegen --silent && vite dev",
    "build": "panda codegen --silent && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler secret bulk .secrets.web.json --config wrangler.deploy.jsonc && wrangler deploy --config wrangler.deploy.jsonc",
    "test": "vitest run",
    "lint": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "5.91.3",
    "@tanstack/react-router": "1.168.7",
    "@tanstack/react-start": "1.167.2",
    "@tidel/api": "*",
    "@trpc/client": "11.14.1",
    "@trpc/react-query": "11.14.1",
    "ofetch": "1.5.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.29.1",
    "@fontsource-variable/plus-jakarta-sans": "5.2.8",
    "@fontsource-variable/syne": "5.2.7",
    "@fontsource/opendyslexic": "5.2.5",
    "@pandacss/dev": "1.9.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@tidel/api-worker": "*",
    "@tidel/tsconfig": "*",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "fontaine": "0.8.0",
    "happy-dom": "20.8.8",
    "vite": "8.0.1",
    "vitest": "4.1.2"
  }
}
